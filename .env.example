# ============================================================
# BACKEND CONFIGURATION
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=True

# Azure OpenAI Configuration (Required for Agent)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-02-15
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Agent Service
AGENT_BASE_URL=http://localhost:5000

# Database (SQLite - automatic)
DATABASE_URL=sqlite:///data/pharmacy.db

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================

# VAPI Voice Configuration (Optional)
VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_AGENT_ID=your_vapi_agent_id_here
VAPI_WEBHOOK_URL=http://localhost:5000/chat/voice-webhook

# API Configuration
API_BASE_URL=http://localhost:5000

# ============================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================

# LangSmith (Optional - for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=pharmly-hackfusion

# Webhook Notifications (Optional)
WEBHOOK_URL=https://n8n.srv1403775.hstgr.cloud/webhook/pharmacy-events-v2

# ============================================================
# SECURITY
# ============================================================

# Admin Token for protected endpoints
ADMIN_TOKEN=your_secure_admin_token_here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================================
# DEPLOYMENT
# ============================================================

# Running Mode
RUN_MODE=development

# Port
PORT=5000

# Host
HOST=127.0.0.1
